# Runpod Serverless image — HY-Motion + retargeting, entrypoint is the Runpod
# handler. Models ARE baked in (see the bake layer below) so workers load them
# from local SSD at cold start — no per-cold-start download, no network volume.
# This makes the image large (~30 GB) but cold starts fast and reliable.
FROM nvidia/cuda:12.1.1-runtime-ubuntu22.04

ENV DEBIAN_FRONTEND=noninteractive
ENV PYTHONUNBUFFERED=1

RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 python3-pip python3-dev git \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Pin to HY-Motion's exact torch (torch==2.5.1) but from the CUDA index, so the
# later `pip install -r requirements.txt` finds it already satisfied and does NOT
# reinstall a CPU build over it.
RUN pip3 install --no-cache-dir torch==2.5.1 torchvision==0.20.1 --index-url https://download.pytorch.org/whl/cu121

# HY-Motion repo (git submodule) + its deps
COPY vendor/HY-Motion-1.0 /opt/HY-Motion-1.0
RUN pip3 install --no-cache-dir -r /opt/HY-Motion-1.0/requirements.txt

ENV HYMOTION_REPO_PATH=/opt/HY-Motion-1.0
ENV PYTHONPATH=/opt/HY-Motion-1.0

RUN ln -s /opt/HY-Motion-1.0/scripts scripts \
    && ln -s /opt/HY-Motion-1.0/stats stats

# App deps + the two extras the handler needs: runpod (serverless) + boto3 (R2).
COPY requirements.txt .
RUN pip3 install --no-cache-dir -r requirements.txt \
    && pip3 install --no-cache-dir "huggingface-hub[hf_xet]" runpod boto3

# Runtime config.
ENV DEVICE=cuda
ENV MODEL_VARIANT=lite
ENV ENABLE_PROMPT_REWRITE=false
ENV MODEL_CACHE_DIR=/data/models
ENV HF_HOME=/data/models/hf
# text_encoder.py reads USE_HF_MODELS to pick HF ids (Qwen/Qwen3-8B, openai/clip-...).
ENV USE_HF_MODELS=1

# ---- Bake all model weights into the image ------------------------------------
# HY-Motion's Lite variant needs three sets at runtime:
#   1) tencent/HY-Motion-1.0 -> HY-Motion-1.0-Lite/ checkpoint       (~1.8 GB)
#   2) Qwen/Qwen3-8B         -> the REQUIRED text encoder            (~16 GB)
#   3) openai/clip-vit-large-patch14 -> the 768-dim sentence encoder (~1.7 GB)
# Downloading them here (before the app COPY, so handler edits don't re-fetch)
# means cold starts read from local SSD instead of the network. The checkpoint
# goes to MODEL_CACHE_DIR (matches app/config.py MODEL_PATH); Qwen/CLIP land in
# the HF cache (HF_HOME), where from_pretrained finds them.
RUN python3 -c "from huggingface_hub import snapshot_download; \
snapshot_download('tencent/HY-Motion-1.0', allow_patterns='HY-Motion-1.0-Lite/*', local_dir='/data/models'); \
snapshot_download('Qwen/Qwen3-8B'); \
snapshot_download('openai/clip-vit-large-patch14')"

# Everything the model needs is on disk now — never touch the hub at cold start
# (also skips slow per-file etag checks). Safe because all three sets are baked.
ENV HF_HUB_OFFLINE=1
ENV TRANSFORMERS_OFFLINE=1

COPY app/ ./app/
COPY runpod_handler.py .

CMD ["python3", "runpod_handler.py"]
