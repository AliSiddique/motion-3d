# Device: "cuda" for GPU (recommended), "cpu" for CPU-only (slow, ~1-3 min per generation)
DEVICE=cpu

# GPU device IDs (comma-separated)
DEVICE_IDS=0

# Model variant: "lite" (0.46B, 24GB VRAM) or "full" (1.0B, 26GB VRAM)
MODEL_VARIANT=lite

# Local model cache directory (models download here from HuggingFace)
MODEL_CACHE_DIR=/data/models

# Override resolved model path (default: MODEL_CACHE_DIR/<variant folder>)
# MODEL_PATH=/data/models/HY-Motion-1.0-Lite

# Disable LLM prompt rewriting to save VRAM
ENABLE_PROMPT_REWRITE=false

# Fewer seeds = less VRAM
DEFAULT_NUM_SEEDS=1

# Server port
PORT=8100
